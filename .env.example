# 백엔드 API Base URL. 미설정 시 자동:
#   - 브라우저가 http://localhost:5173 (Vite dev) → http://localhost:8084 (직접 구동 백엔드)
#   - 그 외 localhost/127.0.0.1 (Docker Nginx 등) → http://localhost:8080
#   - 그 외 → 현재 origin
# 필요 시 아래만 .env에 설정 (저장소에 커밋하지 말 것).
# VITE_API_BASE_URL=http://localhost:8080
# VITE_API_BASE_URL=http://localhost:8084
# VITE_API_BASE_URL=https://api.EXAMPLE_DOMAIN
